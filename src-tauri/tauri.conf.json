{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel/master/nickel.rs",
  "productName": "Iroh Transfer",
  "version": "0.1.5",
  "identifier": "com.iroh.transfer",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Iroh Transfer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc://localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDOTVBQjk3ODk4MTQ3Q0IKUldUTFI0R0psNnVWL1AyU3lBZ21vb1BTSHR5RFdsS25JVi8vaW45WWhJYXBTR0lJVVU1OEw2cDMK",
      "endpoints": [
        "https://github.com/xinyi-it/iroh-transfer/releases/latest/download/latest.json"
      ]
    }
  }
}
