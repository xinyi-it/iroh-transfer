{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for iroh-transfer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:webview:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "updater:default"
  ]
}
